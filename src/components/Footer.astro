---
import type { Lang } from '../content';
import { content } from '../content';
import Brand from './Brand.astro';
interface Props { lang: Lang }
const { lang } = Astro.props;
const footer = content[lang].footer;
---

<footer class="site-footer">
  <div class="shell footer-main"><Brand lang={lang} footer /><p>{footer.line}</p></div>
  <div class="shell footer-bottom"><p>© {new Date().getFullYear()} Forger. {footer.rights}</p><nav aria-label={lang === 'es' ? 'Enlaces secundarios' : 'Secondary links'}><a href="https://forger.cloud/privacy">{footer.privacy}</a><a href="https://forger.cloud">{footer.personal}</a></nav></div>
</footer>
