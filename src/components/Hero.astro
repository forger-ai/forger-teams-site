---
import type { Lang } from '../content';
import { content } from '../content';
interface Props { lang: Lang }
const { lang } = Astro.props;
const copy = content[lang].hero;
---

<section class="hero section" data-section="hero">
  <div class="hero-orbit" aria-hidden="true"></div>
  <div class="shell hero-grid">
    <div class="hero-copy">
      <p class="eyebrow"><span></span>{copy.eyebrow}</p>
      <h1>{copy.title}</h1>
      <p class="hero-lede">{copy.body}</p>
      <div class="hero-actions">
        <a class="button button-primary" href="#contact">{copy.primary}<span aria-hidden="true">→</span></a>
        <a class="button button-secondary" href="#use-cases">{copy.secondary}</a>
      </div>
      <p class="hero-note">{copy.note}</p>
    </div>
    <div class="hero-system" aria-label={lang === 'es' ? 'Los tres pilares de Forger Teams' : 'The three pillars of Forger Teams'}>
      <div class="system-core">
        <img src="/forger-logo.svg" alt="" width="512" height="512" />
        <span>Forger</span><strong>Teams</strong>
      </div>
      <ol>
        {copy.pillars.map((pillar) => (
          <li><span>{pillar.number}</span><div><strong>{pillar.title}</strong><small>{pillar.body}</small></div></li>
        ))}
      </ol>
    </div>
  </div>
</section>
