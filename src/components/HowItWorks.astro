---
import type { Lang } from '../content';
import { content } from '../content';
interface Props { lang: Lang }
const { lang } = Astro.props;
const copy = content[lang].how;
---

<section id="how-it-works" class="section section-stone" data-section="how-it-works">
  <div class="shell how-grid">
    <div>
      <div class="section-heading"><p class="eyebrow dark"><span></span>{copy.eyebrow}</p><h2>{copy.title}</h2></div>
      <ol class="how-steps">
        {copy.steps.map((step) => <li><span>{step.number}</span><div><h3>{step.title}</h3><p>{step.body}</p></div></li>)}
      </ol>
    </div>
    <div class="review-panel">
      <div class="review-tabs">{copy.states.map((state, index) => <span class={index === 1 ? 'selected' : ''}>{state}</span>)}</div>
      <div class="review-content"><span class="review-badge">2 / 3</span><div class="review-glyph" aria-hidden="true">✓</div><h3>{copy.preview}</h3><p>{copy.detail}</p><div class="change-lines" aria-hidden="true"><i></i><i></i><i></i></div><div class="review-actions" aria-hidden="true"><span>{copy.revise}</span><span>{copy.approve}</span></div></div>
    </div>
  </div>
</section>
