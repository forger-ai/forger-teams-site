---
import '../styles/global.css';
import type { Lang } from '../content';
import { content } from '../content';

interface Props { lang: Lang }
const { lang } = Astro.props;
const copy = content[lang];
const canonical = lang === 'es' ? 'https://teams.forger.cloud/es/' : 'https://teams.forger.cloud/';
const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    { '@type': 'WebSite', '@id': 'https://teams.forger.cloud/#website', url: 'https://teams.forger.cloud/', name: 'Forger Teams', inLanguage: ['en', 'es'] },
    { '@type': 'Organization', '@id': 'https://teams.forger.cloud/#organization', name: 'Forger', url: 'https://forger.cloud/', logo: 'https://teams.forger.cloud/forger-logo.svg' },
  ],
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="theme-color" content="#141528" />
    <meta name="description" content={copy.meta.description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="en" href="https://teams.forger.cloud/" />
    <link rel="alternate" hreflang="es" href="https://teams.forger.cloud/es/" />
    <link rel="alternate" hreflang="x-default" href="https://teams.forger.cloud/" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Forger Teams" />
    <meta property="og:title" content={copy.meta.title} />
    <meta property="og:description" content={copy.meta.description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content="https://teams.forger.cloud/og.jpg" />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={copy.meta.imageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={copy.meta.title} />
    <meta name="twitter:description" content={copy.meta.description} />
    <meta name="twitter:image" content="https://teams.forger.cloud/og.jpg" />
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>
    <title>{copy.meta.title}</title>
  </head>
  <body>
    <a class="skip-link" href="#main">{lang === 'es' ? 'Saltar al contenido' : 'Skip to content'}</a>
    <slot />
  </body>
</html>
